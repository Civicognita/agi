# Aionima environment — secrets live here (file permissions: 0600)
# Run `aionima setup` to configure interactively, or copy this file
# to .env and fill in the values you need.

# =============================================================================
# LLM Provider (at least one required)
# =============================================================================

# Anthropic (default provider)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (alternative/failover)
# OPENAI_API_KEY=sk-proj-...

# =============================================================================
# Gateway Authentication
# =============================================================================

# Bearer token for API access (auto-generated by `aionima setup`)
# AUTH_TOKEN=

# =============================================================================
# Channel Tokens (enable the ones you use)
# =============================================================================

# Telegram — get from @BotFather
# TELEGRAM_BOT_TOKEN=

# Discord — get from Discord Developer Portal
# DISCORD_BOT_TOKEN=

# Signal — signal-cli REST API URL
# SIGNAL_API_URL=http://localhost:8080

# WhatsApp Business API
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Gmail OAuth2
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=

# =============================================================================
# Optional
# =============================================================================

# Dashboard auth JWT secret (auto-generated by `aionima setup` if enabled)
# JWT_SECRET=

# GitHub webhook HMAC secret (for auto-deploy detection)
# WEBHOOK_SECRET=

# Whisper API key (falls back to OPENAI_API_KEY if unset)
# WHISPER_API_KEY=
